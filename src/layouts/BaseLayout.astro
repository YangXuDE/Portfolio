---
// Learn about using Astro layouts:
// https://docs.astro.build/en/basics/layouts/

import Footer from '../components/Footer.astro';
// Component Imports
import MainHead from '../components/MainHead.astro';
import Nav from '../components/Nav.astro';

interface Props {
	title?: string | undefined;
	description?: string | undefined;
	hideSocials?: boolean;
}

const { title, description, hideSocials = false } = Astro.props;
const base = import.meta.env.BASE_URL;
const assets = {
	bgMainLight: `${base}assets/backgrounds/bg-main-light-800w.jpg`,
	bgMainLightCurves: `${base}assets/backgrounds/bg-main-light.svg`,
	bgMainDark: `${base}assets/backgrounds/bg-main-dark-800w.jpg`,
	bgMainDarkCurves: `${base}assets/backgrounds/bg-main-dark.svg`,
	bgSubtle1Light: `${base}assets/backgrounds/bg-subtle-1-light-800w.jpg`,
	bgSubtle2Light: `${base}assets/backgrounds/bg-subtle-2-light-800w.jpg`,
	bgFooterLight: `${base}assets/backgrounds/bg-footer-light-800w.jpg`,
	bgSubtle1Dark: `${base}assets/backgrounds/bg-subtle-1-dark-800w.jpg`,
	bgSubtle2Dark: `${base}assets/backgrounds/bg-subtle-2-dark-800w.jpg`,
	bgFooterDark: `${base}assets/backgrounds/bg-footer-dark-800w.jpg`,
	bgMainLightLg: `${base}assets/backgrounds/bg-main-light-1440w.jpg`,
	bgMainDarkLg: `${base}assets/backgrounds/bg-main-dark-1440w.jpg`,
	bgSubtle1LightLg: `${base}assets/backgrounds/bg-subtle-1-light-1440w.jpg`,
	bgSubtle2LightLg: `${base}assets/backgrounds/bg-subtle-2-light-1440w.jpg`,
	bgFooterLightLg: `${base}assets/backgrounds/bg-footer-light-1440w.jpg`,
	bgSubtle1DarkLg: `${base}assets/backgrounds/bg-subtle-1-dark-1440w.jpg`,
	bgSubtle2DarkLg: `${base}assets/backgrounds/bg-subtle-2-dark-1440w.jpg`,
	bgFooterDarkLg: `${base}assets/backgrounds/bg-footer-dark-1440w.jpg`,
	noise: `${base}assets/backgrounds/noise.png`,
};
---

<html lang="en">
	<head>
		<MainHead title={title} description={description} />
	</head>
	<body>
		<div class="stack backgrounds" class:list={[{ 'hide-socials': hideSocials }]}>
			{hideSocials ? null : <Nav />}
			<slot />
			{hideSocials ? null : <Footer />}
		</div>

		<script>
			// Add “loaded” class once the document has completely loaded.
			addEventListener('load', () => document.documentElement.classList.add('loaded'));
		</script>

		<style define:vars={assets}>
			:root {
				--_placeholder-bg: linear-gradient(transparent, transparent);
				--bg-image-main: url(var(--bgMainLight));
				--bg-image-main-curves: url(var(--bgMainLightCurves));
				--bg-image-subtle-1: var(--_placeholder-bg);
				--bg-image-subtle-2: var(--_placeholder-bg);
				--bg-image-footer: var(--_placeholder-bg);
				--bg-svg-blend-mode: overlay;
				--bg-blend-mode: darken;
				--bg-image-aspect-ratio: 2.25;
				--bg-scale: 1.68;
				--bg-aspect-ratio: calc(var(--bg-image-aspect-ratio) / var(--bg-scale));
				--bg-gradient-size: calc(var(--bg-scale) * 100%);
			}

			:root.theme-dark {
				--bg-image-main: url(var(--bgMainDark));
				--bg-image-main-curves: url(var(--bgMainDarkCurves));
				--bg-svg-blend-mode: darken;
				--bg-blend-mode: lighten;
			}

			/* These backgrounds are displayed below the fold, so we lazy load them
			   once the `.loaded` class has been set.  */
			:root.loaded {
				--bg-image-subtle-1: url(var(--bgSubtle1Light));
				--bg-image-subtle-2: url(var(--bgSubtle2Light));
				--bg-image-footer: url(var(--bgFooterLight));
			}
			:root.loaded.theme-dark {
				--bg-image-subtle-1: url(var(--bgSubtle1Dark));
				--bg-image-subtle-2: url(var(--bgSubtle2Dark));
				--bg-image-footer: url(var(--bgFooterDark));
			}

			@media (min-width: 50em) {
				:root {
					--bg-scale: 1;
					--bg-image-main: url(var(--bgMainLightLg));
				}
				:root.theme-dark {
					--bg-image-main: url(var(--bgMainDarkLg));
				}

				:root.loaded {
					--bg-image-subtle-1: url(var(--bgSubtle1LightLg));
					--bg-image-subtle-2: url(var(--bgSubtle2LightLg));
					--bg-image-footer: url(var(--bgFooterLightLg));
				}
				:root.loaded.theme-dark {
					--bg-image-subtle-1: url(var(--bgSubtle1DarkLg));
					--bg-image-subtle-2: url(var(--bgSubtle2DarkLg));
					--bg-image-footer: url(var(--bgFooterDarkLg));
				}
			}

			.backgrounds {
				min-height: 100%;
				isolation: isolate;
				background:
					/*noise*/
					url(var(--noise)) top center/220px repeat,
					/*footer*/ var(--bg-image-footer) bottom center/var(--bg-gradient-size) no-repeat,
					/*header1*/ var(--bg-image-main-curves) top center/var(--bg-gradient-size) no-repeat,
					/*header2*/ var(--bg-image-main) top center/var(--bg-gradient-size) no-repeat,
					/*base*/ var(--gray-999);
				background-blend-mode: /*noise*/
					overlay,
					/*footer*/ var(--bg-blend-mode),
					/*header1*/ var(--bg-svg-blend-mode),
					/*header2*/ normal,
					/*base*/ normal;
			}
			@media (forced-colors: active) {
				/* Deactivate custom backgrounds for high contrast users. */
				.backgrounds {
					background: none;
					background-blend-mode: none;
					--bg-gradient-size: none;
				}
			}

			/* Hide socials for standalone mode */
			.hide-socials {
				background: var(--gray-999);
			}
		</style>
		{hideSocials && <style is:global>
			nav, footer { display: none !important; }
		</style>}
	</body>
</html>
